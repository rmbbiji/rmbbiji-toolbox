" Minimal Vim config: common settings only, no plugins required.
set encoding=utf-8
filetype plugin indent on
syntax enable
set number
set mouse=a
set backspace=indent,eol,start
set expandtab
set tabstop=4
set shiftwidth=4
set autoindent
set smartindent
set ignorecase
set smartcase
set incsearch
set hlsearch
